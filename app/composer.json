{
    "name": "tcloud/storage-system",
    "description": "TCloud Storage System - Self-hosted cloud storage similar to NextCloud",
    "type": "project",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0",
        "predis/predis": "^2.0",
        "aws/aws-sdk-php": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
